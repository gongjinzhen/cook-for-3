{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Backend",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/backend/server.js",
            "outputCapture": "std",
            "console": "integratedTerminal"
        },
        {
            "name": "Frontend",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/frontend/node_modules/vite/bin/vite.js",
            "args": ["--host"],
            "outputCapture": "std",
            "console": "integratedTerminal"
        }
    ],
    "compounds": [
        {
            "name": "Start All",
            "configurations": ["Backend", "Frontend"],
            "stopAll": true
        }
    ]
}
